{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "rootDir": "../../",
    "outDir": "dist",
    "types": [
      "node"
    ],
    "noEmit": false
  },
  "include": [
    "src/**/*.ts"
  ]
}
