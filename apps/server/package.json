{
  "name": "@filler/server",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development nest start --watch",
    "build": "tsc -p tsconfig.json",
    "start": "NODE_ENV=production nest start",
    "db:up": "docker compose -f docker-compose.mongo-local.yml up -d",
    "db:down": "docker compose -f docker-compose.mongo-local.yml down",
    "db:logs": "docker compose -f docker-compose.mongo-local.yml logs -f mongodb"
  },
  "dependencies": {
    "@filler/game-core": "file:../../packages/game-core",
    "@filler/shared": "file:../../packages/shared",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-ws": "^10.4.15",
    "@nestjs/websockets": "^10.4.15",
    "dotenv": "^16.6.1",
    "mongodb": "^6.17.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
